rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Usuários ──────────────────────────────────────────────────────────────
    match /usuarios/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['premium', 'plano', 'dataExpiracaoPremium']);
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['premium', 'plano', 'dataExpiracaoPremium']);
    }

    // ── Modalidades ───────────────────────────────────────────────────────────
    match /modalidades/{modalidadeId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Concursos ─────────────────────────────────────────────────────────────
    match /concursos/{concursoId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Apostas do usuário ────────────────────────────────────────────────────
    match /apostas_usuario/{apostaId} {
      allow read:   if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && !request.resource.data.keys().hasAny(['acertos', 'statusConferencia', 'concursoConferido']);
      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['acertos', 'statusConferencia', 'concursoConferido', 'conferidoEm']);
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // ── Estatísticas ─────────────────────────────────────────────────────────
    match /estatisticas/{modalidadeId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Ranking de Sorte ─────────────────────────────────────────────────────
    // Leitura pública. Usuário só cria entrada com seu próprio userId.
    // Sem update/delete — entradas são imutáveis após registro.
    match /ranking/{entryId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.keys().hasAll(['userId', 'displayName', 'acertos', 'modalidadeId'])
        && (request.resource.data.displayName is string)
        && (request.resource.data.displayName.size() >= 2)
        && (request.resource.data.acertos is int);
      allow update, delete: if false;
    }
  }
}
